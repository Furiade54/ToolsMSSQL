{
  "name": "toolsmssql",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json -w\" \"tsc -p tsconfig.preload.json -w\" \"wait-on http://127.0.0.1:5173 dist/main/main.cjs dist/preload/preload.cjs && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json",
    "build": "npm run build:renderer && npm run build:electron",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.renderer.json && tsc -p tsconfig.node.json && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "preview": "vite preview",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.furiade54.toolsmssql",
    "productName": "ToolsMSSQL",
    "directories": {
      "output": "release"
    },
    "artifactName": "ToolsMSSQL-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Furiade54",
        "repo": "ToolsMSSQL"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
